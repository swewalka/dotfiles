# ~/.config/hypr/hyprpaper.conf

wallpaper {
    monitor = DP-1
    path = /home/nepo/.config/hypr/wallpapers/code_blocks_light.png
    fit_mode = cover
}

wallpaper {
    monitor = DP-3
    path = /home/nepo/.config/hypr/wallpapers/canvas-light.png
    fit_mode = cover
}

wallpaper {
    monitor = HDMI-A-1
    path = /home/nepo/.config/hypr/wallpapers/canvas-light.png
    fit_mode = cover
}

splash = false
ipc = true

